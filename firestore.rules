rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Trade Validation
    function isValidTrade(data) {
      return data.userId == request.auth.uid &&
             data.index is string && data.index.size() <= 50 &&
             data.type in ['Buy', 'Sell'] &&
             data.pnl is number &&
             data.date is string &&
             data.entry is number &&
             data.exit is number &&
             data.lotSize is number &&
             data.strategy is string &&
             data.keys().hasAll(['userId', 'date', 'entry', 'exit', 'lotSize', 'type', 'strategy', 'index', 'pnl', 'createdAt', 'mistakes', 'notes']) &&
             data.keys().size() >= 11;
    }

    function isValidSettings(data) {
      return data.monthlyGoal is number &&
             data.updatedAt == request.time &&
             data.keys().hasAll(['monthlyGoal', 'updatedAt']) &&
             data.keys().size() == 2;
    }

    match /trades/{tradeId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && 
                      isValidId(tradeId) && 
                      isValidTrade(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow update: if isOwner(existing().userId) && 
                      isValidTrade(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      (
                        // Action: Full Update of trade details
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'date', 'entryTime', 'exitTime', 'entry', 'exit', 'sl', 'tp', 
                          'lotSize', 'type', 'strategy', 'index', 'mood', 'mistakes', 
                          'entryCondition', 'exitCondition', 'notes', 'pnl', 'rr', 
                          'screenshot', 'updatedAt'
                        ])
                      );
      
      allow delete: if isOwner(existing().userId);
    }

    match /settings/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidSettings(incoming());
    }
  }
}
